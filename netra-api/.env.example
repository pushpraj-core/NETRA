# ─────────────────────────────────────────────────────────────────────────────
# N.E.T.R.A. API — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB connection string
# Local:   mongodb://127.0.0.1:27017/netra
# Atlas:   mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/netra?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/netra

# Port the Express server will listen on
PORT=5000

# Allowed origins for CORS (comma-separated if multiple)
# e.g. http://localhost:5173,https://netra.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: explicit Python interpreter used to run NETRA-AI/pipeline.py
# macOS/Linux example: /Users/you/Downloads/N.E.T.R.A.-master 2/NETRA-AI/.venv/bin/python3
# Windows example: C:\\path\\to\\N.E.T.R.A.-master 2\\NETRA-AI\\.venv\\Scripts\\python.exe
# PYTHON_PATH=
